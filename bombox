-- [ ٣. سیستەمێ دراگکرنا پانێلێ (Draggable) ]
local dragging, dragInput, dragStart, startPos
panel.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = panel.Position
        input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
    end
end)
panel.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        panel.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

local function findBoomboxOwner(sound)
	local cur = sound
	for i = 1, 6 do
		if not cur then break end
		if cur:IsA("Tool") and cur.Name:lower():find("boom") then
			local p = Players:GetPlayerFromCharacter(cur.Parent)
			if p then return p, cur end
		end
		cur = cur.Parent
	end
	return nil, nil
end

local function handlePotentialSound(sound)
	if not sound:IsA("Sound") or sound.SoundId == "" then return end
	local owner, source = findBoomboxOwner(sound)
	if not (owner or (source and tostring(source):lower():find("boom"))) then return end
	local key = tostring(sound.SoundId)
	if lastSeen[key] and (os.time() - lastSeen[key] < RECENT_IGNORE_SECONDS) then return end
	lastSeen[key] = os.time()
	createEntry(sound.SoundId, owner and owner.Name or "Unknown")
end

workspace.DescendantAdded:Connect(function(desc)
	if desc:IsA("Sound") then task.delay(0.1, function() pcall(function() handlePotentialSound(desc) end) end) end
end)

